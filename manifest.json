{
  "manifest_version": 3,
  "name": "Copy as Markdown Link",
  "version": "1.0",
  "permissions": ["clipboardWrite", "activeTab", "scripting", "storage"],
  "commands": {
    "copy-markdown": {
      "suggested_key": { "default": "Ctrl+Shift+C", "mac": "Command+Shift+C" },
      "description": "Copy page as markdown link"
    }
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Copy as Markdown Link",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
