{
  "manifest_version": 3,
  "name": "MC* - Markdown Copy",
  "version": "26.5",
  "permissions": ["clipboardWrite", "activeTab", "scripting", "storage"],
  "commands": {
    "copy-markdown": {
      "suggested_key": { "default": "Ctrl+Shift+C", "mac": "Command+Shift+C" },
      "description": "Copy page as markdown link"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": "icons/icon.png",
    "default_title": "MC* - Markdown Copy",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
